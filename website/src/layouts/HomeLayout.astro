---
export interface Props {
  title: string;
  description: string;
  lang: 'zh' | 'en';
  currentPath: string;
}
const { title, description, lang, currentPath } = Astro.props;

const enHref = '/en/';
const zhHref = '/';
const isEn = lang === 'en';

const schemaName = isEn ? 'Zebin Li' : '李泽斌';
const schemaJob = isEn ? 'LLM Inference Infra Engineer' : 'LLM推理Infra工程师';
const schemaAlumni = isEn ? 'Shanghai Jiao Tong University' : '上海交通大学';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content={isEn ? "Zebin Li,KVCache,virtualization,MiniMax,IPADS,Shanghai Jiao Tong University,LLM inference" : "李泽斌,KVCache,虚拟化,MiniMax,IPADS,上海交通大学,LLM推理,大模型 inference"}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="icon" href="/avatar.jpg">
  <link rel="sitemap" href="/sitemap-index.xml">

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={`https://cutelizebin.github.io${currentPath}`}>
  <meta property="og:type" content="profile">
  <meta property="og:image" content="https://cutelizebin.github.io/avatar.jpg">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={isEn ? "LLM Inference Infra Engineer" : "LLM推理Infra工程师"}>
  <meta name="twitter:image" content="https://cutelizebin.github.io/avatar.jpg">

  <!-- Schema.org Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": schemaName,
    "url": "https://cutelizebin.github.io",
    "sameAs": [
      "https://github.com/cutelizebin",
      "https://x.com/Zebin_Li98",
      "https://www.linkedin.com/in/zebin-li/"
    ],
    "jobTitle": schemaJob,
    "worksFor": {
      "@type": "Organization",
      "name": "MiniMax"
    },
    "alumniOf": {
      "@type": "Organization",
      "name": schemaAlumni
    }
  })}></script>
</head>
<body>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="profile">
        <img src="/avatar.jpg" alt={isEn ? "Avatar" : "头像"} class="avatar" width="100" height="100">
        <h1 class="name">{isEn ? "Zebin Li" : "李泽斌"}</h1>
        <p class="title">ENFJ</p>
        <p class="lang-switch">
          <a href={enHref} class={isEn ? "active" : ""}>English</a>
          <span class="divider">|</span>
          <a href={zhHref} class={isEn ? "" : "active"}>中文</a>
        </p>
      </div>
      <button class="menu-toggle" id="menuToggle" aria-label={isEn ? "Toggle menu" : "切换菜单"}>
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="sidebar-body" id="sidebarBody">
      <nav class="nav">
        <a href={isEn ? "/en/#about" : "#about"} class="nav-link" data-section="about">{isEn ? "About" : "关于"}</a>
        <a href={isEn ? "/en/#activity" : "#activity"} class="nav-link" data-section="activity">{isEn ? "Activity" : "活动"}</a>
        <a href={isEn ? "/en/#news" : "#news"} class="nav-link" data-section="news">{isEn ? "Timeline" : "时间线"}</a>
        <a href={isEn ? "/en/#projects" : "#projects"} class="nav-link" data-section="projects">{isEn ? "Projects" : "项目"}</a>
        <a href={isEn ? "/en/#blog" : "#blog"} class="nav-link" data-section="blog">{isEn ? "Blog" : "博客"}</a>
        <a href={isEn ? "/en/#knowledge" : "#knowledge"} class="nav-link" data-section="knowledge">{isEn ? "Knowledge" : "知识库"}</a>
        <a href={isEn ? "/en/#contact" : "#contact"} class="nav-link" data-section="contact">{isEn ? "Contact" : "联系"}</a>
      </nav>

      <div class="social">
        <a href="https://github.com/cutelizebin" target="_blank"><i class="fa-brands fa-github"></i> GitHub</a>
        <a href="https://x.com/Zebin_Li98" target="_blank"><i class="fa-brands fa-x-twitter"></i> X</a>
        <a href="https://www.linkedin.com/in/zebin-li/" target="_blank"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>
      </div>
    </div>
  </aside>

  <main class="main" id="main">
    <slot />
  </main>

  <button id="back-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" title={isEn ? "Back to top" : "返回顶部"}>↑</button>

  <script>
    // Mobile menu toggle
    var toggle = document.getElementById('menuToggle');
    var body = document.getElementById('sidebarBody');
    if (toggle && body) {
      toggle.addEventListener('click', function() {
        body.classList.toggle('open');
        toggle.classList.toggle('open');
      });
      // Close menu on nav link click
      body.querySelectorAll('.nav-link').forEach(function(link) {
        link.addEventListener('click', function() {
          body.classList.remove('open');
          toggle.classList.remove('open');
        });
      });
    }

    // Active section: click + scroll tracking
    var navLinks = document.querySelectorAll('.nav-link');
    var sections = document.querySelectorAll('.section');

    function setActive(hash) {
      navLinks.forEach(function(link) {
        link.classList.toggle('active', ('#' + link.dataset.section) === hash);
      });
    }

    // On hash change (link click)
    window.addEventListener('hashchange', function() {
      setActive(window.location.hash);
    });

    // On scroll, update hash silently
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          var current = '';
          sections.forEach(function(s) {
            if (s.getBoundingClientRect().top < window.innerHeight * 0.35) {
              current = '#' + s.id;
            }
          });
          if (current && current !== window.location.hash) {
            history.replaceState(null, '', current);
            setActive(current);
          }
          ticking = false;
        });
        ticking = true;
      }
    });

    setActive(window.location.hash || '#' + (sections.length ? sections[0].id : 'about'));

    // Back to top
    window.addEventListener('scroll', function() {
      var btn = document.getElementById('back-to-top');
      if (window.scrollY > 300) {
        btn.style.display = 'block';
      } else {
        btn.style.display = 'none';
      }
    });
  </script>

  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #f9fafb;
      --sidebar-bg: #f2f3f7;
      --text: #1e293b;
      --text-light: #64748b;
      --accent: #2563eb;
      --accent-light: #dbeafe;
      --border: #e2e8f0;
      --hover: #eef2ff;
      --card-bg: #ffffff;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-hover: 0 4px 12px rgba(0,0,0,0.08);
      --sidebar-width: 240px;
      --content-max-width: 960px;
      --radius: 12px;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      color: var(--text);
      line-height: 1.7;
      background: var(--bg);
    }

    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: var(--sidebar-width);
      height: 100vh;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      padding: 32px 20px;
      display: flex;
      flex-direction: column;
      z-index: 100;
    }

    .sidebar-header {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .menu-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      flex-direction: column;
      gap: 5px;
    }

    .menu-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }

    .menu-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .menu-toggle.open span:nth-child(2) { opacity: 0; }
    .menu-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    .sidebar-body {
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .profile {
      text-align: center;
    }

    .avatar {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 12px;
      border: 3px solid white;
      box-shadow: var(--shadow);
    }

    .name {
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .title {
      font-size: 13px;
      color: var(--text-light);
      margin-top: 2px;
    }

    .lang-switch {
      margin-top: 10px;
      margin-bottom: 24px;
    }

    .lang-switch a {
      font-size: 12px;
      color: var(--accent);
      text-decoration: none;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 6px;
      transition: all 0.2s;
    }

    .lang-switch a:hover {
      background: var(--hover);
    }

    .lang-switch a.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    .lang-switch .divider {
      margin: 0 4px;
      color: var(--text-light);
    }

    .nav {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .nav-link {
      display: block;
      padding: 8px 14px;
      border-radius: 8px;
      text-decoration: none;
      color: var(--text-light);
      font-size: 14px;
      font-weight: 500;
      transition: all 0.2s;
    }

    .nav-link:hover {
      background: var(--hover);
      color: var(--accent);
    }

    .nav-link.active {
      background: var(--accent);
      color: white;
    }

    .social {
      margin-top: auto;
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      padding-top: 24px;
    }

    .social a {
      font-size: 12px;
      color: var(--text-light);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 6px 10px;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .social a:hover {
      color: var(--accent);
      background: var(--hover);
    }

    .social .fa-brands {
      font-size: 14px;
    }

    .main {
      margin-left: var(--sidebar-width);
      padding: 48px 48px;
      max-width: var(--content-max-width);
    }

    .section {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 28px 32px;
      margin-bottom: 24px;
      box-shadow: var(--shadow);
      transition: box-shadow 0.3s;
    }

    .section:hover {
      box-shadow: var(--shadow-hover);
    }

    .section:target {
      box-shadow: 0 0 0 2px var(--accent), var(--shadow-hover);
    }

    .section h2 {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section p {
      margin-bottom: 12px;
      color: var(--text);
      font-size: 15px;
      line-height: 1.75;
    }

    .section a {
      color: var(--accent);
      text-decoration: none;
    }

    .section a:hover {
      text-decoration: underline;
    }

    .section .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 24px;
      background: var(--accent);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s;
    }

    .section .btn:hover {
      opacity: 0.9;
      text-decoration: none;
      box-shadow: var(--shadow);
    }

    .news-list {
      list-style: none;
      padding-left: 0;
    }

    .news-list li {
      padding: 14px 0 14px 24px;
      border-left: 2px solid var(--border);
      position: relative;
      margin-left: 10px;
    }

    .news-list li:last-child {
      border-left-color: transparent;
    }

    .news-list li::before {
      content: '';
      position: absolute;
      left: -7px;
      top: 20px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #7c3aed);
      box-shadow: 0 0 0 2px white;
    }

    .news-list .date {
      color: var(--accent);
      font-size: 12px;
      font-weight: 600;
      display: block;
      margin-bottom: 4px;
      letter-spacing: 0.02em;
    }

    .news-list .sub-event {
      margin-top: 8px;
      padding: 10px 0 10px 28px;
      position: relative;
      background: var(--bg);
      border-radius: 8px;
      margin-left: -8px;
    }

    .news-list .sub-event::before {
      content: '';
      position: absolute;
      left: 10px;
      top: -8px;
      width: 2px;
      height: 8px;
      background: var(--border);
    }

    .news-list .sub-event::after {
      content: '';
      position: absolute;
      left: 0;
      top: -4px;
      width: 18px;
      height: 2px;
      background: var(--border);
    }

    .news-list .sub-event .date {
      font-size: 11px;
      color: var(--accent);
      font-weight: 600;
    }

    .news-list .sub-event p {
      font-size: 13px;
      margin-top: 4px;
    }

    .news-list .sub-event a {
      font-size: 12px;
    }

    .project-list {
      list-style: none;
    }

    .project-list li {
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
      transition: background 0.2s;
      margin: 0 -12px;
      padding: 12px 12px;
      border-radius: 8px;
    }

    .project-list li:last-child {
      border-bottom: none;
    }

    .project-list li:hover {
      background: var(--bg);
    }

    .project-list p {
      font-size: 14px;
      color: var(--text-light);
      margin-top: 4px;
      line-height: 1.6;
    }

    #back-to-top {
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 40px;
      height: 40px;
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      font-size: 18px;
      display: none;
      z-index: 1000;
      box-shadow: var(--shadow);
      transition: all 0.2s;
    }

    #back-to-top:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-hover);
    }

    @media (max-width: 768px) {
      .sidebar {
        position: fixed;
        width: 100%;
        height: auto;
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 12px 16px;
        background: rgba(242, 243, 247, 0.98);
        backdrop-filter: blur(8px);
      }

      .sidebar-header {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }

      .profile {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .avatar {
        width: 40px;
        height: 40px;
        margin-bottom: 0;
        border-width: 2px;
      }

      .name {
        font-size: 16px;
        margin-bottom: 0;
      }

      .title {
        display: none;
      }

      .lang-switch {
        margin: 0;
        margin-left: auto;
        margin-bottom: 0;
      }

      .lang-switch a {
        font-size: 11px;
        padding: 2px 8px;
      }

      .lang-switch .divider {
        display: none;
      }

      .menu-toggle {
        display: flex;
      }

      .sidebar-body {
        display: none;
        position: fixed;
        top: 65px;
        left: 0;
        width: 100%;
        height: calc(100vh - 65px);
        background: rgba(242, 243, 247, 0.98);
        backdrop-filter: blur(8px);
        padding: 16px 20px;
        overflow-y: auto;
      }

      .sidebar-body.open {
        display: flex;
      }

      .nav {
        flex-direction: column;
      }

      .nav-link {
        padding: 12px 16px;
        font-size: 16px;
      }

      .social {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .main {
        margin-left: 0;
        padding: 80px 16px 24px;
      }

      .section {
        padding: 20px;
        margin-bottom: 16px;
      }

      .section h2 {
        font-size: 18px;
      }
    }
  </style>
</body>
</html>
