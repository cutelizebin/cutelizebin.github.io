---
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout
  title="404 - 页面未找到"
  description="Page not found"
  lang="zh"
  currentPath={Astro.url.pathname}
>
  <section class="section" style="text-align:center;padding:80px 0">
    <h2>404</h2>
    <p style="font-size:18px;margin:16px 0">页面未找到</p>
    <a href="/" style="display:inline-block;margin-top:16px;padding:8px 24px;background:#2563eb;color:white;text-decoration:none;border-radius:8px">返回主页</a>
  </section>
</HomeLayout>
